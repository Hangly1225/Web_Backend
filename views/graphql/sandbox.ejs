<p>Execute GraphQL-style queries and mutations directly against <code>/api/graphql</code>.</p>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; align-items:start;">
    <section>
      <h3>Query editor</h3>
      <textarea id="query" style="width:100%; min-height:260px;"><%= sampleQuery %></textarea>
      <h3>Variables</h3>
      <textarea id="variables" style="width:100%; min-height:120px;"><%= sampleVariables %></textarea>
      <p>
        <button id="run-query" type="button">Run query</button>
      </p>
      <pre id="result" style="background:#111827; color:#f9fafb; padding:12px; overflow:auto; min-height:240px;"></pre>
    </section>

    <section>
      <h3>Schema</h3>
      <pre style="background:#f5f5f5; padding:12px; overflow:auto; min-height:600px;"><%= schema %></pre>
    </section>
  </div>

  <script>
    const button = document.getElementById('run-query');
    const queryEditor = document.getElementById('query');
    const variablesEditor = document.getElementById('variables');
    const result = document.getElementById('result');

    button.addEventListener('click', async () => {
      result.textContent = 'Running...';
      let variables = {};

      try {
        variables = JSON.parse(variablesEditor.value || '{}');
      } catch (error) {
        result.textContent = `Invalid variables JSON: ${error.message}`;
        return;
      }

      const response = await fetch('/api/graphql', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query: queryEditor.value,
          variables,
          operationName: 'SandboxOperation'
        })
      });
      const payload = await response.json();
      result.textContent = JSON.stringify(payload, null, 2);
    });
  </script>
<%- include('../partials/footer') %>