<article style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 12px;">
    <img src="<%= product.image %>" alt="<%= product.title %>" style="width: 100%; height: 220px; object-fit: cover; border-radius: 6px;" />
    <h3><%= product.title %></h3>
    <p><%= product.price %></p>
    <button type="button">Add to cart</button>
  </article>