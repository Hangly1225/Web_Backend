<%- include('../partials/head', { pageTitle, user, menuItems }) %>
  <h3>Edit product #<%= product.id %></h3>
  <form action="/products/<%= product.id %>/edit" method="post">
    <label>Name</label>
    <input name="name" value="<%= product.name %>" required />
    <label>Description</label>
    <input name="description" value="<%= product.description %>" required />
    <label>Price</label>
    <input name="price" type="number" step="0.01" value="<%= product.price %>" required />
    <label>Stock</label>
    <input name="stock" type="number" min="0" value="<%= product.stock %>" required />
    <label>Category</label>
    <select name="categoryId" required>
      <% categories.forEach(function(c){ %>
        <option value="<%= c.id %>" <%= c.id === product.categoryId ? 'selected' : '' %>><%= c.name %></option>
      <% }) %>
    </select>
    <button type="submit">Save</button>
  </form>
<%- include('../partials/footer') %>