<%- include('partials/head', { pageTitle: pageTitle || 'Home', user: userName || null, menuItems }) %>
  <h2>Featured products</h2>
  <p>
    Session state:
    <% if (isAuthenticated) { %>
      <strong>Authorized</strong>
    <% } else { %>
      <strong>Unauthorized</strong>
    <% } %>
  </p>

  <section style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px;">
    <% products.forEach((product) => { %>
      <%- include('partials/product-card', { product }) %>
    <% }) %>
  </section>
<%- include('partials/footer') %>