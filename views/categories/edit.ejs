<%- include('../partials/head', { pageTitle, user, menuItems }) %>
  <h3>Edit category #<%= category.id %></h3>
  <form action="/categories/<%= category.id %>/edit" method="post">
    <label>Name</label>
    <input name="name" value="<%= category.name %>" required />
    <label>Brand</label>
    <select name="brandId" required>
      <% brands.forEach(function(brand) { %>
        <option value="<%= brand.id %>" <%= brand.id === category.brandId ? 'selected' : '' %>><%= brand.name %></option>
      <% }) %>
    </select>
    <button type="submit">Save</button>
  </form>
<%- include('../partials/footer') %>