<%- include('../partials/head', { pageTitle, user, menuItems }) %>
  <h3>Edit order #<%= order.id %></h3>
  <form action="/orders/<%= order.id %>/edit" method="post">
    <label>User</label>
    <select name="userId" required>
      <% users.forEach(function(user) { %>
        <option value="<%= user.id %>" <%= user.id === order.userId ? 'selected' : '' %>><%= user.username %> (<%= user.email %>)</option>
      <% }) %>
    </select>
    <label>Status</label>
    <select name="status" required>
      <% statuses.forEach(function(status) { %>
        <option value="<%= status %>" <%= status === order.status ? 'selected' : '' %>><%= status %></option>
      <% }) %>
    </select>
    <label>Product</label>
    <select name="productId">
      <option value="">-- Keep current items --</option>
      <% products.forEach(function(product) { %>
        <option value="<%= product.id %>" <%= selectedProductId === product.id ? 'selected' : '' %>>
          <%= product.name %> ($<%= product.price %>)
        </option>
      <% }) %>
    </select>
    <label>Quantity</label>
    <input name="quantity" type="number" min="1" value="<%= selectedQuantity %>" />
    <button type="submit">Save</button>
  </form>
<%- include('../partials/footer') %>