<%- include('../partials/head', { title: 'Users' }) %>
<%- include('../partials/header') %>
<main>
  <h3>Users</h3>
  <table>
    <thead>
      <tr><th>ID</th><th>Username</th><th>Email</th><th>Orders</th><th>Cart items</th></tr>
    </thead>
    <tbody>
      <% users.forEach(function(user) { %>
        <tr>
          <td><%= user.id %></td>
          <td><%= user.username %></td>
          <td><%= user.email %></td>
          <td><%= user.orders?.length || 0 %></td>
          <td><%= user.cartItems?.length || 0 %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</main>
<%- include('../partials/footer') %>